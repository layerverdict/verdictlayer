# ============================================================
# Verdict — Environment Template
# Copy to .env and fill in values. NEVER commit .env
# ============================================================

# --- Network: Testnet (Galileo) — default for development ---
CHAIN_ID=16602
RPC_URL=https://evmrpc-testnet.0g.ai
STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
BLOCK_EXPLORER=https://chainscan-galileo.0g.ai

# --- Network: Mainnet (Aristotle) — switch for prod deploy ---
