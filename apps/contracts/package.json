{
  "name": "@verdict/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "hardhat compile && ts-node scripts/export-abis.ts",
    "compile": "hardhat compile",
    "export:abis": "ts-node scripts/export-abis.ts",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "coverage": "hardhat coverage",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network ogTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network ogMainnet",
    "node": "hardhat node",
    "clean": "hardhat clean && rm -rf .turbo typechain-types artifacts cache coverage",
    "lint": "echo 'lint skipped'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@verdict/shared": "workspace:*",
    "chai": "^4.5.0",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}
