{
  "name": "@verdict/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "echo 'lint skipped'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "validate:tee": "tsx scripts/validate-tee.cts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "0.6.5",
    "@0glabs/0g-ts-sdk": "^0.3.3",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@verdict/shared": "workspace:*",
    "bullmq": "^5.76.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.16.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
